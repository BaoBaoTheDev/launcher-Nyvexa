{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nyvexa Launcher",
  "version": "1.0.4",
  "identifier": "com.nyvexa.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nyvexa Launcher V1.0.4",
        "width": 1024,
        "height": 640,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "backgroundColor": "#181a21"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co; img-src 'self' data: blob: https:; media-src 'self' blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico"
      }
    },
    "resources": {
      "../.env.enc": ".env.enc"
    }
  }
}
