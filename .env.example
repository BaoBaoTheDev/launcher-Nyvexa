# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin emails (comma separated)
ADMIN_EMAILS=

# SMTP (Gmail) - dùng App Password, không phải mật khẩu thường
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Nyvexa Launcher <your-gmail@gmail.com>

# Optional encrypted env secret (must match Electron build)
NESTG_ENV_SECRET=nestg-launcher-env-secret-v1
